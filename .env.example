# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets.

# LLM re-ranking (optional) — required only for --llm-rerank flag.
# Uses a LOCAL Ollama server only; no hosted-LLM provider/API key needed.
# Start one with `ollama serve` and `ollama pull qwen2.5:7b`.
OLLAMA_BASE_URL=http://100.96.26.32:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Optional ──────────────────────────────────────────────────────────────────
DATA_DIR=./data
OUTPUT_DIR=./outputs
CACHE_DIR=./outputs/cache
WANDB_PROJECT=india-runs-track1
WANDB_ENTITY=
HF_TOKEN=
EMBED_MODEL=BAAI/bge-large-en-v1.5
DEVICE=cpu

# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets.

# ── Required for LLM listwise re-ranking (--llm-rerank flag) ─────────────────
# Gemini race-runner uses gemini-2.5-flash / 2.5-flash-lite / 1.5-flash in parallel
GOOGLE_API_KEY=

# ── Optional (legacy / fallback) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DATA_DIR=./data
OUTPUT_DIR=./outputs
CACHE_DIR=./outputs/cache
WANDB_PROJECT=india-runs-track1
WANDB_ENTITY=
HF_TOKEN=
EMBED_MODEL=BAAI/bge-large-en-v1.5
DEVICE=cpu
